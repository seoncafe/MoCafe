&parameters
 !--- Biconical clump distribution: clumps are placed only within a cone of
 !--- half-opening angle cone_opening (degrees) about the +/- z axis
 !--- (exercises the cone placement / fully-inside cone rejection).
 par%no_photons      = 2.0e6
 par%hgg             = 0.0
 par%albedo          = 0.5
 par%source_geometry = 'point'
 par%save_direc0     = .true.

 par%grid_type        = 'clump'
 par%rmax             = 1.0
 par%clump_radius     = 0.06
 par%clump_f_cov      = 0.5
 par%clump_tau0       = 1.0
 par%cone_opening     = 45.0
 par%clump_fully_inside = .false.   ! centers in the cone; clumps may straddle its edge
 par%save_clump_info  = .true.

 par%distance_unit   = ''
 par%nxim = 129
 par%nyim = 129
 par%obsx = 1.0
 par%obsy = 0.0
 par%obsz = 0.0
 par%distance = 1.0e+03

 par%use_master_slave = .false.
 par%iseed    = 0
 par%no_print = 2.0e6
 par%file_format = 'fits'
 par%out_file    = 'clump_cone'
/
